{
  "name": "tic-tac-toe",
  "dependencies": {
    "@vue/reactivity": "^3.2.36",
    "classnames": "^2.3.1",
    "lit-html": "^2.2.5",
    "modern-normalize": "^1.1.0"
  },
  "scripts": {
    "start": "parcel ./src/index.html --open --no-cache",
    "prebuild": "rimraf dist",
    "build": "parcel build ./src/index.html --public-url ./ --no-cache",
    "format": "prettier --write 'src/**/*.js'"
  },
  "devDependencies": {
    "parcel": "^2.6.0",
    "prettier": "^2.6.2",
    "rimraf": "^3.0.2"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ],
  "@parcel/transformer-css": {
    "drafts": {
      "nesting": true
    }
  }
}
